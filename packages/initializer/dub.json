{
	"name": "initializer",
	"description": "The in-pod init container: provisions the agent's environment (clone repos, install the agent CLI) before the supervisor runs.",
	"license": "Apache-2.0",
	"targetType": "executable",
	"targetName": "ai-agent-init",
	"dependencies": {
		"ai-agent-subsystem:agentcore": "*"
	},
	"buildTypes": {
		"static": {
			"buildOptions": ["releaseMode", "optimize", "inline"]
		}
	},
	"configurations": [
		{
			"name": "application"
		},
		{
			"name": "unittest",
			"dependencies": {
				"fluent-asserts": "~>2.0.5"
			}
		}
	]
}
