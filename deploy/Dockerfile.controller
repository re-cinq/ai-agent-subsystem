# syntax=docker/dockerfile:1
#
# The controller image (ghcr.io/re-cinq/ai-agent-controller). Multi-stage: build
# the controller with the official ldc (static druntime, like the agent image),
# then a minimal glibc runtime with libssl3 (vibe-d links it dynamically). Runs
# non-root, matching deploy/controller.yaml's securityContext.
#
# Builder: rockylinux:9 — its glibc (2.34) is the oldest in the runtime/Station
# matrix (rocky/amazonlinux/debian/ubuntu), so the static-druntime binary it builds
# runs on every glibc >= 2.34, not just bookworm's 2.36. The OFFICIAL ldc release
# (dlang.org install.sh) ships the static druntime/phobos that
# `-link-defaultlib-shared=false` needs — the EPEL ldc package ships only shared.
#
ARG BUILDER_IMAGE=rockylinux:9
ARG RUNTIME_IMAGE=debian:bookworm-slim
ARG LDC_VERSION=1.40.0
ARG LDC_SHA256=0da61ed2ea96583aa0ccbeb00f8d78983b23d1e87b84a6f2098eb12059475b27

FROM ${BUILDER_IMAGE} AS builder
ARG LDC_VERSION
ARG LDC_SHA256
RUN set -eu; \
	dnf install -y --setopt=install_weak_deps=False \
		curl-minimal xz tar gzip coreutils gcc glibc-devel zlib-devel openssl-devel libxml2 git ca-certificates; \
	dnf clean all
# Pinned, checksum-verified official LDC release tarball — no curl|bash of an
# unverified installer. The version and hash move together.
RUN set -eu; \
	tarball="ldc2-${LDC_VERSION}-linux-x86_64.tar.xz"; \
	curl -fsSL -o "/tmp/${tarball}" \
		"https://github.com/ldc-developers/ldc/releases/download/v${LDC_VERSION}/${tarball}"; \
	echo "${LDC_SHA256}  /tmp/${tarball}" | sha256sum -c -; \
	mkdir -p /opt/dlang; \
	tar -C /opt/dlang -xf "/tmp/${tarball}"; \
	rm -f "/tmp/${tarball}"
ENV PATH="/opt/dlang/ldc2-${LDC_VERSION}-linux-x86_64/bin:${PATH}"
WORKDIR /src
COPY . .
RUN DFLAGS="-link-defaultlib-shared=false -L-lz" dub build :controller --compiler=ldc2

FROM ${RUNTIME_IMAGE} AS runtime
RUN set -eu; \
	export DEBIAN_FRONTEND=noninteractive; \
	apt-get update; \
	apt-get install -y --no-install-recommends ca-certificates libssl3; \
	rm -rf /var/lib/apt/lists/*
COPY --from=builder /src/packages/controller/ai-agent-controller /usr/local/bin/ai-agent-controller
USER 1000
ENTRYPOINT ["/usr/local/bin/ai-agent-controller"]
